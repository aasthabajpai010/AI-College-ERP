{
  "info": {
    "name": "AI-Integrated College ERP System",
    "description": "Full API collection for the College ERP backend — Auth, Departments, Students, Attendance, Results. Uses collection variables for baseUrl and tokens so no manual copy-pasting is needed during a live demo.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api" },
    { "key": "adminToken", "value": "" },
    { "key": "facultyToken", "value": "" },
    { "key": "studentToken", "value": "" },
    { "key": "departmentId", "value": "6a4cd79bd683720ad25c4bf3" },
    { "key": "studentId", "value": "6a4f1bfe43970d9cd9a050f4" },
    { "key": "studentUserId", "value": "" },
    { "key": "noticeId", "value": "" }
  ],
  "item": [
    {
      "name": "1. Auth",
      "item": [
        {
          "name": "Register Admin",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Admin User\",\n  \"email\": \"admin@test.com\",\n  \"password\": \"123456\",\n  \"role\": \"admin\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] }
          }
        },
        {
          "name": "Register Faculty",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Faculty User\",\n  \"email\": \"faculty@test.com\",\n  \"password\": \"123456\",\n  \"role\": \"faculty\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] }
          }
        },
        {
          "name": "Register Student",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Student\",\n  \"email\": \"student@test.com\",\n  \"password\": \"123456\",\n  \"role\": \"student\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] }
          }
        },
        {
          "name": "Login Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.token) { pm.collectionVariables.set('adminToken', data.token); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@test.com\",\n  \"password\": \"123456\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          },
          "description": "Auto-saves the token into {{adminToken}} via the Tests script — no manual copy-paste needed."
        },
        {
          "name": "Login Faculty",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.token) { pm.collectionVariables.set('facultyToken', data.token); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"faculty@test.com\",\n  \"password\": \"123456\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "Login Student",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.token) { pm.collectionVariables.set('studentToken', data.token); }",
                  "if (data.user && data.user.id) { pm.collectionVariables.set('studentUserId', data.user.id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"student@test.com\",\n  \"password\": \"123456\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "Login - Wrong Password (expect 400)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@test.com\",\n  \"password\": \"wrongpassword\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          }
        }
      ]
    },
    {
      "name": "2. Departments",
      "item": [
        {
          "name": "Create Department (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.department && data.department._id) { pm.collectionVariables.set('departmentId', data.department._id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Computer Science\",\n  \"code\": \"CSE\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/departments", "host": ["{{baseUrl}}"], "path": ["departments"] }
          }
        },
        {
          "name": "Get All Departments",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/departments", "host": ["{{baseUrl}}"], "path": ["departments"] }
          }
        },
        {
          "name": "Update Department (Admin)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Computer Science & Engineering\"\n}" },
            "url": { "raw": "{{baseUrl}}/departments/{{departmentId}}", "host": ["{{baseUrl}}"], "path": ["departments", "{{departmentId}}"] }
          }
        },
        {
          "name": "Delete Department (Admin only - do not run during demo)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/departments/{{departmentId}}", "host": ["{{baseUrl}}"], "path": ["departments", "{{departmentId}}"] }
          }
        }
      ]
    },
    {
      "name": "3. Students",
      "item": [
        {
          "name": "Create Student (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.student && data.student._id) { pm.collectionVariables.set('studentId', data.student._id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user\": \"{{studentUserId}}\",\n  \"department\": \"{{departmentId}}\",\n  \"rollNumber\": \"CS2024001\",\n  \"semester\": 3,\n  \"section\": \"A\",\n  \"phone\": \"9999999999\",\n  \"address\": \"Test Address\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/students", "host": ["{{baseUrl}}"], "path": ["students"] }
          },
          "description": "Run 'Login Student' first so {{studentUserId}} is populated, and 'Create Department' so {{departmentId}} is populated."
        },
        {
          "name": "Get All Students (Admin/Faculty)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/students", "host": ["{{baseUrl}}"], "path": ["students"] }
          }
        },
        {
          "name": "Get Student By ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/students/{{studentId}}", "host": ["{{baseUrl}}"], "path": ["students", "{{studentId}}"] }
          }
        },
        {
          "name": "Update Student (Admin)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"semester\": 4,\n  \"section\": \"B\"\n}" },
            "url": { "raw": "{{baseUrl}}/students/{{studentId}}", "host": ["{{baseUrl}}"], "path": ["students", "{{studentId}}"] }
          }
        },
        {
          "name": "RBAC Check - Student tries Create (expect 403)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{studentToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user\": \"{{studentUserId}}\",\n  \"department\": \"{{departmentId}}\",\n  \"rollNumber\": \"CS2024999\",\n  \"semester\": 1,\n  \"section\": \"A\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/students", "host": ["{{baseUrl}}"], "path": ["students"] }
          },
          "description": "Demonstrates RBAC — student role is blocked from creating student records (403 Forbidden)."
        },
        {
          "name": "Delete Student (Admin only - do not run during demo)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/students/{{studentId}}", "host": ["{{baseUrl}}"], "path": ["students", "{{studentId}}"] }
          }
        }
      ]
    },
    {
      "name": "4. Attendance",
      "item": [
        {
          "name": "Mark Attendance - Present (Admin/Faculty)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"student\": \"{{studentId}}\",\n  \"date\": \"2026-07-01\",\n  \"status\": \"present\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/attendance", "host": ["{{baseUrl}}"], "path": ["attendance"] }
          }
        },
        {
          "name": "Mark Attendance - Absent (different date)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"student\": \"{{studentId}}\",\n  \"date\": \"2026-07-02\",\n  \"status\": \"absent\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/attendance", "host": ["{{baseUrl}}"], "path": ["attendance"] }
          }
        },
        {
          "name": "Duplicate Attendance (expect 400)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"student\": \"{{studentId}}\",\n  \"date\": \"2026-07-01\",\n  \"status\": \"present\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/attendance", "host": ["{{baseUrl}}"], "path": ["attendance"] }
          },
          "description": "Same student + same date as the first Mark Attendance request — demonstrates the compound unique index rejecting duplicates."
        },
        {
          "name": "Get Student Attendance (list)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/attendance/{{studentId}}", "host": ["{{baseUrl}}"], "path": ["attendance", "{{studentId}}"] }
          }
        },
        {
          "name": "Get Attendance Percentage (Aggregation)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/attendance/{{studentId}}/percentage", "host": ["{{baseUrl}}"], "path": ["attendance", "{{studentId}}", "percentage"] }
          },
          "description": "Good one to highlight live — shows the aggregation pipeline result."
        },
        {
          "name": "Get Defaulter List (Aggregation, Admin/Faculty)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/attendance/defaulters", "host": ["{{baseUrl}}"], "path": ["attendance", "defaulters"] }
          }
        }
      ]
    },
    {
      "name": "5. Results",
      "item": [
        {
          "name": "Add Result - Subject 1 (Admin/Faculty)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"student\": \"{{studentId}}\",\n  \"subject\": \"Data Structures\",\n  \"semester\": 3,\n  \"marksObtained\": 85,\n  \"maxMarks\": 100\n}"
            },
            "url": { "raw": "{{baseUrl}}/results", "host": ["{{baseUrl}}"], "path": ["results"] }
          }
        },
        {
          "name": "Add Result - Subject 2 (Admin/Faculty)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"student\": \"{{studentId}}\",\n  \"subject\": \"Operating Systems\",\n  \"semester\": 3,\n  \"marksObtained\": 70,\n  \"maxMarks\": 100\n}"
            },
            "url": { "raw": "{{baseUrl}}/results", "host": ["{{baseUrl}}"], "path": ["results"] }
          }
        },
        {
          "name": "Duplicate Result (expect 400)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"student\": \"{{studentId}}\",\n  \"subject\": \"Data Structures\",\n  \"semester\": 3,\n  \"marksObtained\": 60,\n  \"maxMarks\": 100\n}"
            },
            "url": { "raw": "{{baseUrl}}/results", "host": ["{{baseUrl}}"], "path": ["results"] }
          }
        },
        {
          "name": "Get Student Results",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/results/{{studentId}}", "host": ["{{baseUrl}}"], "path": ["results", "{{studentId}}"] }
          }
        },
        {
          "name": "Get CGPA (Aggregation)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/results/{{studentId}}/cgpa", "host": ["{{baseUrl}}"], "path": ["results", "{{studentId}}", "cgpa"] }
          },
          "description": "Good one to highlight live — shows the aggregation pipeline result (average %, CGPA on 10-point scale)."
        }
      ]
    },
    {
      "name": "6. Dashboard",
      "item": [
        {
          "name": "Admin Dashboard (Aggregation)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/dashboard/admin", "host": ["{{baseUrl}}"], "path": ["dashboard", "admin"] }
          },
          "description": "College-wide summary: totalStudents, totalDepartments, departmentWiseCount, averageAttendancePercentage, gradeDistribution. Admin/Faculty only."
        },
        {
          "name": "Student Dashboard (Aggregation)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/dashboard/student/{{studentId}}", "host": ["{{baseUrl}}"], "path": ["dashboard", "student", "{{studentId}}"] }
          },
          "description": "One student's own summary: attendancePercentage, cgpa, totalSubjects."
        },
        {
          "name": "RBAC Check - Student tries Admin Dashboard (expect 403)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{studentToken}}" }],
            "url": { "raw": "{{baseUrl}}/dashboard/admin", "host": ["{{baseUrl}}"], "path": ["dashboard", "admin"] }
          },
          "description": "Demonstrates RBAC — student role is blocked from the college-wide admin dashboard (403 Forbidden)."
        }
      ]
    },
    {
      "name": "7. Notices",
      "item": [
        {
          "name": "Create Notice (Admin/Faculty)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.notice && data.notice._id) { pm.collectionVariables.set('noticeId', data.notice._id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Exam Schedule Released\",\n  \"content\": \"The semester exam schedule has been published. Check the portal for details.\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/notices", "host": ["{{baseUrl}}"], "path": ["notices"] }
          },
          "description": "Creates a notice AND emits a Socket.IO 'newNotice' event to any connected client. Watch this fire live if you have a Socket.IO request connected in another tab."
        },
        {
          "name": "Create Notice - Department Specific",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"CSE Department Meeting\",\n  \"content\": \"All CSE students must attend the department meeting on Friday.\",\n  \"department\": \"{{departmentId}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/notices", "host": ["{{baseUrl}}"], "path": ["notices"] }
          }
        },
        {
          "name": "Get All Notices",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/notices", "host": ["{{baseUrl}}"], "path": ["notices"] }
          },
          "description": "Returns notices sorted newest-first, with postedBy populated (name, role)."
        },
        {
          "name": "RBAC Check - Student tries Create Notice (expect 403)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{studentToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Unauthorized Notice\",\n  \"content\": \"This should be blocked.\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/notices", "host": ["{{baseUrl}}"], "path": ["notices"] }
          },
          "description": "Demonstrates RBAC — student role is blocked from posting official notices (403 Forbidden)."
        }
      ]
    }
  ]
}